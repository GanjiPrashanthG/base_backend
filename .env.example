NODE_ENV=development
HOST=127.0.0.1
PORT=3000
LOG_PRETTY=0
MONGODB_ENABLED=1
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB_NAME=mayday
# Prisma reads DATABASE_URL; if unset it is built from MONGODB_URI + MONGODB_DB_NAME + pool/timeouts
DATABASE_URL=mongodb://127.0.0.1:27017/mayday?serverSelectionTimeoutMS=5000&maxPoolSize=10
# Comma-separated origins; in production omit to deny CORS unless set
# CORS_ORIGIN=https://app.example.com
JSON_BODY_LIMIT_MB=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
# Behind nginx/ALB: hop count for X-Forwarded-* (0 = off). Enables correct client IP for rate limiting.
# TRUST_PROXY_HOPS=1
# HTTP_REQUEST_TIMEOUT_MS=60000
# HTTP_HEADERS_TIMEOUT_MS=65000
# SHUTDOWN_GRACE_MS=15000
# ADMIN_API_KEY=change-me
# SENTRY_DSN=
# SENTRY_RELEASE=mayday-api@1.0.0
# SENTRY_ENABLE_LOGS=0
# SENTRY_SEND_DEFAULT_PII=0
# SENTRY_ENABLE_PROFILING=0
# MONGO_MIGRATE_CHANGELOG_NAME=mongo_migrate_changelog
# METRICS_REQUIRE_AUTH=0

# AWS ECS Fargate — environment variables for task definition
# Copy each key/value into ECS console or CodePipeline task def.
# Put secrets in Secrets Manager; reference as secrets, not plain env.
#
# ALB target group: health check path /health, port traffic port 3000, success 200.
# Troubleshooting unhealthy targets: deploy/alb-health-check.md

NODE_ENV=production
HOST=0.0.0.0
PORT=3000
LOG_PRETTY=0

MONGODB_ENABLED=1
MONGODB_DB_NAME=mayday
MONGODB_MAX_POOL_SIZE=5
DATABASE_URL=mongodb+srv://prashanthganji2021:<db_password>@cluster0.2bcej.mongodb.net/mayday?retryWrites=true&w=majority&appName=Cluster0&serverSelectionTimeoutMS=5000&maxPoolSize=5

TRUST_PROXY_HOPS=1

JSON_BODY_LIMIT_MB=1
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
HTTP_REQUEST_TIMEOUT_MS=60000
HTTP_HEADERS_TIMEOUT_MS=65000
SHUTDOWN_GRACE_MS=15000

ADMIN_API_KEY=<from-secrets-manager>
SENTRY_DSN=<from-secrets-manager>

API_DOCS_ENABLED=0
METRICS_ENABLED=1
METRICS_REQUIRE_AUTH=1

SENTRY_RELEASE=mayday-api@1.0.1
SENTRY_ENABLE_LOGS=0
SENTRY_SEND_DEFAULT_PII=0
SENTRY_ENABLE_PROFILING=0

MONGO_MIGRATE_CHANGELOG_NAME=mongo_migrate_changelog

# Optional
# CORS_ORIGIN=https://your-frontend.example.com

// Prisma MongoDB — `DATABASE_URL` must be set for `prisma generate` / `prisma db push`
// (e.g. mongodb://127.0.0.1:27017/mayday?serverSelectionTimeoutMS=5000&maxPoolSize=10)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

/// Starter model — extend or replace with your domain collections.
model Item {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())

  @@map("items")
}
